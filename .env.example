# IRC connection
IRC_HOST=irc.example.com
IRC_PORT=6697
IRC_TLS=true
IRC_NICK=jukebox

# SASL login. The account is registered automatically (IRCv3
# account-registration) if it doesn't exist yet; IRC_REGISTER_EMAIL is sent only
# when the server requires an address.
IRC_SASL_USER=jukebox
IRC_SASL_PASS=
IRC_REGISTER=true
IRC_REGISTER_EMAIL=

# The stream channel the bot publishes to and takes commands in. These are the
# server's $-prefixed WebRTC channels, not regular # channels.
VOICE_CHANNEL=$stream

# STUN server for NAT traversal — it discovers the bot's public address so peers
# can connect directly. The IRC server hands out its own TURN relay on join; this
# only covers the reflexive-address step, so any public STUN works.
STUN_URL=stun:stun.l.google.com:19302

# Comma-separated logged-in accounts allowed to run the .show commands.
ADMIN_ACCOUNTS=

# Fallback channel: plays a Jellyfin series whenever the queue is idle. Leave
# JELLYFIN_API_KEY blank to disable the .show commands entirely.
JELLYFIN_URL=http://jellyfin:8096
JELLYFIN_API_KEY=
FALLBACK_SERIES=
JELLYFIN_BURN_SUBTITLES=true

# Optional yt-dlp cookies file, for sources behind age/region gates.
YTDLP_COOKIES=

# Video output.
VIDEO_WIDTH=1280
VIDEO_HEIGHT=720
VIDEO_FPS=30
IDLE_IMAGE=

# REST API. A blank API_KEY leaves it unauthenticated (gate at the edge instead).
MAX_QUEUE=100
HTTP_BIND=0.0.0.0
HTTP_PORT=8080
API_KEY=

LOG_LEVEL=info
